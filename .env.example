# Reconcile-Ops environment template.
# Copy to `.env` and fill in as needed. `.env` is gitignored — never commit secrets.
#
# Nothing here is required to run the core pipeline (generate -> reconcile -> KPIs).
# These are placeholders for optional future integrations.

# --- Optional: LLM-assisted break triage / narrative summaries ---
# ANTHROPIC_API_KEY=

# --- Optional: notification sink for reconciliation alerts ---
# SLACK_WEBHOOK_URL=

# --- Pipeline knobs (override defaults; all optional) ---
# Amount tolerance in currency units when comparing expected vs settled net.
# RECON_AMOUNT_TOLERANCE=0.01
# Settlement SLA in hours; settlements later than this are flagged late.
# RECON_SLA_HOURS=48
