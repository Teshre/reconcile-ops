# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- Test / tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Secrets / local config ---
.env
.env.local

# --- Generated data & pipeline output (regenerated via `make data`) ---
data/*.csv
out/
# ...but keep the out/ directory itself tracked so the pipeline has a target.
!out/.gitkeep

# --- OS / editor cruft ---
.DS_Store
.idea/
.vscode/
*.swp
